{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "FieldDemo",
  "dependencies": [],
  "files": [
    {
      "path": "registry/base/examples/FieldDemo.res",
      "content": "type item = {\n  label: string,\n  value: string,\n}\n\nlet months: array<item> = [\n  {label: \"MM\", value: \"\"},\n  {label: \"01\", value: \"01\"},\n  {label: \"02\", value: \"02\"},\n  {label: \"03\", value: \"03\"},\n  {label: \"04\", value: \"04\"},\n  {label: \"05\", value: \"05\"},\n  {label: \"06\", value: \"06\"},\n  {label: \"07\", value: \"07\"},\n  {label: \"08\", value: \"08\"},\n  {label: \"09\", value: \"09\"},\n  {label: \"10\", value: \"10\"},\n  {label: \"11\", value: \"11\"},\n  {label: \"12\", value: \"12\"},\n]\n\nlet years: array<item> = [\n  {label: \"YYYY\", value: \"\"},\n  {label: \"2024\", value: \"2024\"},\n  {label: \"2025\", value: \"2025\"},\n  {label: \"2026\", value: \"2026\"},\n  {label: \"2027\", value: \"2027\"},\n  {label: \"2028\", value: \"2028\"},\n  {label: \"2029\", value: \"2029\"},\n]\n\n@react.component\nlet make = () =>\n  <div className=\"w-full max-w-md\">\n    <form>\n      <Field.Group>\n        <Field.Set>\n          <Field.Legend> {\"Payment Method\"->React.string} </Field.Legend>\n          <Field.Description>\n            {\"All transactions are secure and encrypted\"->React.string}\n          </Field.Description>\n          <Field.Group>\n            <Field>\n              <Field.Label htmlFor=\"checkout-7j9-card-name-43j\">\n                {\"Name on Card\"->React.string}\n              </Field.Label>\n              <Input id=\"checkout-7j9-card-name-43j\" placeholder=\"Evil Rabbit\" required={true}>\n                {React.null}\n              </Input>\n            </Field>\n            <Field>\n              <Field.Label htmlFor=\"checkout-7j9-card-number-uw1\">\n                {\"Card Number\"->React.string}\n              </Field.Label>\n              <Input\n                id=\"checkout-7j9-card-number-uw1\" placeholder=\"1234 5678 9012 3456\" required={true}\n              >\n                {React.null}\n              </Input>\n              <Field.Description>\n                {\"Enter your 16-digit card number\"->React.string}\n              </Field.Description>\n            </Field>\n            <div className=\"grid grid-cols-3 gap-4\">\n              <Field>\n                <Field.Label htmlFor=\"checkout-exp-month-ts6\">\n                  {\"Month\"->React.string}\n                </Field.Label>\n                <Select items={months}>\n                  <Select.Trigger id=\"checkout-exp-month-ts6\">\n                    <Select.Value> {\"MM\"->React.string} </Select.Value>\n                  </Select.Trigger>\n                  <Select.Content>\n                    <Select.Group>\n                      {months\n                      ->Array.map(item =>\n                        <Select.Item key={item.value} value={item.value}>\n                          {item.label->React.string}\n                        </Select.Item>\n                      )\n                      ->React.array}\n                    </Select.Group>\n                  </Select.Content>\n                </Select>\n              </Field>\n              <Field>\n                <Field.Label htmlFor=\"checkout-7j9-exp-year-f59\">\n                  {\"Year\"->React.string}\n                </Field.Label>\n                <Select items={years}>\n                  <Select.Trigger id=\"checkout-7j9-exp-year-f59\">\n                    <Select.Value> {\"YYYY\"->React.string} </Select.Value>\n                  </Select.Trigger>\n                  <Select.Content>\n                    <Select.Group>\n                      {years\n                      ->Array.map(item =>\n                        <Select.Item key={item.value} value={item.value}>\n                          {item.label->React.string}\n                        </Select.Item>\n                      )\n                      ->React.array}\n                    </Select.Group>\n                  </Select.Content>\n                </Select>\n              </Field>\n              <Field>\n                <Field.Label htmlFor=\"checkout-7j9-cvv\"> {\"CVV\"->React.string} </Field.Label>\n                <Input id=\"checkout-7j9-cvv\" placeholder=\"123\" required={true}>\n                  {React.null}\n                </Input>\n              </Field>\n            </div>\n          </Field.Group>\n        </Field.Set>\n        <Field.Separator />\n        <Field.Set>\n          <Field.Legend> {\"Billing Address\"->React.string} </Field.Legend>\n          <Field.Description>\n            {\"The billing address associated with your payment method\"->React.string}\n          </Field.Description>\n          <Field.Group>\n            <Field orientation=BaseUi.Types.Orientation.Horizontal>\n              <Checkbox id=\"checkout-7j9-same-as-shipping-wgm\" defaultChecked={true} />\n              <Field.Label htmlFor=\"checkout-7j9-same-as-shipping-wgm\" className=\"font-normal\">\n                {\"Same as shipping address\"->React.string}\n              </Field.Label>\n            </Field>\n          </Field.Group>\n        </Field.Set>\n        <Field.Set>\n          <Field.Group>\n            <Field>\n              <Field.Label htmlFor=\"checkout-7j9-optional-comments\">\n                {\"Comments\"->React.string}\n              </Field.Label>\n              <Textarea\n                id=\"checkout-7j9-optional-comments\"\n                placeholder=\"Add any additional comments\"\n                className=\"resize-none\"\n              >\n                {React.null}\n              </Textarea>\n            </Field>\n          </Field.Group>\n        </Field.Set>\n        <Field orientation=BaseUi.Types.Orientation.Horizontal>\n          <Button type_=\"submit\"> {\"Submit\"->React.string} </Button>\n          <Button variant=Button.Variant.Outline type_=\"button\"> {\"Cancel\"->React.string} </Button>\n        </Field>\n      </Field.Group>\n    </form>\n  </div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}