{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "ItemDemo",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "Button",
    "Icons",
    "Item"
  ],
  "files": [
    {
      "path": "registry/base/examples/ItemDemo.res",
      "content": "@react.componentWithProps(Demo.Props.t)\nlet make = ({}: Demo.Props.t) =>\n  <div className=\"flex w-full max-w-md flex-col gap-6\">\n    <Item variant=Outline>\n      <Item.Content>\n        <Item.Title> {\"Basic Item\"->React.string} </Item.Title>\n        <Item.Description>\n          {\"A simple item with title and description.\"->React.string}\n        </Item.Description>\n      </Item.Content>\n      <Item.Actions>\n        <Button variant=Outline size=Sm> {\"Action\"->React.string} </Button>\n      </Item.Actions>\n    </Item>\n    <Item variant=Outline size=Sm render={<a href=\"#\" />}>\n      <Item.Media>\n        <Icons.BadgeCheck className=\"size-5\" />\n      </Item.Media>\n      <Item.Content>\n        <Item.Title> {\"Your profile has been verified.\"->React.string} </Item.Title>\n      </Item.Content>\n      <Item.Actions>\n        <Icons.ChevronRight className=\"size-4\" />\n      </Item.Actions>\n    </Item>\n  </div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}