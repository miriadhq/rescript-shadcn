{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "EmptyInputGroup",
  "dependencies": [],
  "files": [
    {
      "path": "registry/base/examples/EmptyInputGroup.res",
      "content": "@react.component\nlet make = () =>\n  <Empty>\n    <Empty.Header>\n      <Empty.Title> {\"404 - Not Found\"->React.string} </Empty.Title>\n      <Empty.Description>\n        {\"The page you're looking for doesn't exist. Try searching for what you need below.\"->React.string}\n      </Empty.Description>\n    </Empty.Header>\n    <Empty.Content>\n      <InputGroup className=\"sm:w-3/4\">\n        <InputGroup.Input placeholder=\"Try searching for pages...\" />\n        <InputGroup.Addon>\n          <Icons.Search />\n        </InputGroup.Addon>\n        <InputGroup.Addon align=InlineEnd>\n          <Kbd> {\"/\"->React.string} </Kbd>\n        </InputGroup.Addon>\n      </InputGroup>\n      <Empty.Description>\n        {\"Need help? \"->React.string}\n        <a href=\"#\"> {\"Contact support\"->React.string} </a>\n      </Empty.Description>\n    </Empty.Content>\n  </Empty>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
