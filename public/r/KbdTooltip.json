{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "KbdTooltip",
  "registryDependencies": [
    "Button",
    "ButtonGroup",
    "Kbd",
    "Tooltip"
  ],
  "files": [
    {
      "path": "registry/base/examples/KbdTooltip.res",
      "content": "@react.componentWithProps(Demo.Props.t)\nlet make = ({}: Demo.Props.t) =>\n  <div className=\"flex flex-wrap gap-4\">\n    <ButtonGroup>\n      <Tooltip>\n        <Tooltip.Trigger render={<Button variant=Button.Variant.Outline />}>\n          {\"Save\"->React.string}\n        </Tooltip.Trigger>\n        <Tooltip.Content className=\"pr-1.5\">\n          <div className=\"flex items-center gap-2\">\n            {\"Save Changes \"->React.string}\n            <Kbd> {\"S\"->React.string} </Kbd>\n          </div>\n        </Tooltip.Content>\n      </Tooltip>\n      <Tooltip>\n        <Tooltip.Trigger render={<Button variant=Button.Variant.Outline />}>\n          {\"Print\"->React.string}\n        </Tooltip.Trigger>\n        <Tooltip.Content className=\"pr-1.5\">\n          <div className=\"flex items-center gap-2\">\n            {\"Print Document \"->React.string}\n            <Kbd.Group>\n              <Kbd> {\"Ctrl\"->React.string} </Kbd>\n              <Kbd> {\"P\"->React.string} </Kbd>\n            </Kbd.Group>\n          </div>\n        </Tooltip.Content>\n      </Tooltip>\n    </ButtonGroup>\n  </div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}