{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "DrawerDemo",
  "dependencies": [
    "lucide-react",
    "recharts"
  ],
  "registryDependencies": [
    "Button",
    "Drawer",
    "Icons"
  ],
  "files": [
    {
      "path": "registry/base/examples/DrawerDemo.res",
      "content": "@@directive(\"'use client'\")\n\ntype drawerDatum = {goal: int}\n\nmodule Recharts = {\n  type responsiveContainerProps = {\n    width: string,\n    height: string,\n    children: React.element,\n  }\n\n  module ResponsiveContainer = {\n    @module(\"recharts\")\n    external make: React.component<responsiveContainerProps> = \"ResponsiveContainer\"\n  }\n\n  type barChartProps = {\n    data: array<drawerDatum>,\n    children: React.element,\n  }\n\n  module BarChart = {\n    @module(\"recharts\")\n    external make: React.component<barChartProps> = \"BarChart\"\n  }\n\n  type barProps = {\n    dataKey: string,\n    style?: ReactDOM.Style.t,\n  }\n\n  module Bar = {\n    @module(\"recharts\")\n    external make: React.component<barProps> = \"Bar\"\n  }\n}\n\nlet data: array<drawerDatum> = [\n  {goal: 400},\n  {goal: 300},\n  {goal: 200},\n  {goal: 300},\n  {goal: 200},\n  {goal: 278},\n  {goal: 189},\n  {goal: 239},\n  {goal: 300},\n  {goal: 200},\n  {goal: 278},\n  {goal: 189},\n  {goal: 349},\n]\n\n@react.componentWithProps(Demo.Props.t)\nlet make = ({}: Demo.Props.t) => {\n  let goal = 350\n  <Drawer>\n    <Drawer.Trigger asChild={true}>\n      <Button variant=Button.Variant.Outline dataSlot=\"drawer-trigger\">\n        {\"Open Drawer\"->React.string}\n      </Button>\n    </Drawer.Trigger>\n    <Drawer.Content>\n      <div className=\"mx-auto w-full max-w-sm\">\n        <Drawer.Header>\n          <Drawer.Title> {\"Move Goal\"->React.string} </Drawer.Title>\n          <Drawer.Description> {\"Set your daily activity goal.\"->React.string} </Drawer.Description>\n        </Drawer.Header>\n        <div className=\"p-4 pb-0\">\n          <div className=\"flex items-center justify-center space-x-2\">\n            <Button\n              variant=Button.Variant.Outline\n              size=Button.Size.Icon\n              className=\"h-8 w-8 shrink-0 rounded-full\"\n              onClick={_ => ()}\n              disabled={goal <= 200}\n            >\n              <Icons.Minus />\n              <span className=\"sr-only\"> {\"Decrease\"->React.string} </span>\n            </Button>\n            <div className=\"flex-1 text-center\">\n              <div className=\"text-7xl font-bold tracking-tighter\">\n                {Int.toString(goal)->React.string}\n              </div>\n              <div className=\"text-muted-foreground text-[0.70rem] uppercase\">\n                {\"Calories/day\"->React.string}\n              </div>\n            </div>\n            <Button\n              variant=Button.Variant.Outline\n              size=Button.Size.Icon\n              className=\"h-8 w-8 shrink-0 rounded-full\"\n              onClick={_ => ()}\n              disabled={goal >= 400}\n            >\n              <Icons.Plus />\n              <span className=\"sr-only\"> {\"Increase\"->React.string} </span>\n            </Button>\n          </div>\n          <div className=\"mt-3 h-[120px]\">\n            <Recharts.ResponsiveContainer width=\"100%\" height=\"100%\">\n              <Recharts.BarChart data>\n                <Recharts.Bar dataKey=\"goal\" style={{fill: \"var(--chart-1)\"}} />\n              </Recharts.BarChart>\n            </Recharts.ResponsiveContainer>\n          </div>\n        </div>\n        <Drawer.Footer>\n          <Button> {\"Submit\"->React.string} </Button>\n          <Drawer.Close asChild={true}>\n            <Button variant=Button.Variant.Outline> {\"Cancel\"->React.string} </Button>\n          </Drawer.Close>\n        </Drawer.Footer>\n      </div>\n    </Drawer.Content>\n  </Drawer>\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}