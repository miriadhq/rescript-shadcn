{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "ContextMenuIcons",
  "dependencies": [],
  "files": [
    {
      "path": "registry/base/examples/ContextMenuIcons.res",
      "content": "@react.component\nlet make = () =>\n  <ContextMenu>\n    <ContextMenu.Trigger\n      className=\"flex aspect-video w-full max-w-xs items-center justify-center rounded-xl border border-dashed text-sm\"\n    >\n      <span className=\"hidden pointer-fine:inline-block\"> {\"Right click here\"->React.string} </span>\n      <span className=\"hidden pointer-coarse:inline-block\">\n        {\"Long press here\"->React.string}\n      </span>\n    </ContextMenu.Trigger>\n    <ContextMenu.Content>\n      <ContextMenu.Group>\n        <ContextMenu.Item>\n          <Icons.Copy />\n          {\"Copy\"->React.string}\n        </ContextMenu.Item>\n        <ContextMenu.Item>\n          <Icons.Scissors />\n          {\"Cut\"->React.string}\n        </ContextMenu.Item>\n        <ContextMenu.Item>\n          <Icons.ClipboardPaste />\n          {\"Paste\"->React.string}\n        </ContextMenu.Item>\n      </ContextMenu.Group>\n      <ContextMenu.Separator />\n      <ContextMenu.Group>\n        <ContextMenu.Item variant=ContextMenu.Variant.Destructive>\n          <Icons.Trash />\n          {\"Delete\"->React.string}\n        </ContextMenu.Item>\n      </ContextMenu.Group>\n    </ContextMenu.Content>\n  </ContextMenu>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}