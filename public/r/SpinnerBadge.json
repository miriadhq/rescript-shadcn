{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "SpinnerBadge",
  "registryDependencies": [
    "Badge",
    "Spinner"
  ],
  "files": [
    {
      "path": "registry/base/examples/SpinnerBadge.res",
      "content": "@react.componentWithProps(Demo.Props.t)\nlet make = ({}: Demo.Props.t) =>\n  <div className=\"flex items-center gap-4 [--radius:1.2rem]\">\n    <Badge>\n      <Spinner dataIcon=InlineStart />\n      {\"Syncing\"->React.string}\n    </Badge>\n    <Badge variant=Badge.Variant.Secondary>\n      <Spinner dataIcon=InlineStart />\n      {\"Updating\"->React.string}\n    </Badge>\n    <Badge variant=Badge.Variant.Outline>\n      <Spinner dataIcon=InlineStart />\n      {\"Processing\"->React.string}\n    </Badge>\n  </div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}