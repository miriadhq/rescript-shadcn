{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "KbdRtl",
  "dependencies": [],
  "files": [
    {
      "path": "registry/base/examples/KbdRtl.res",
      "content": "@@directive(\"'use client'\")\n\n@react.component\nlet make = () =>\n  <div className=\"flex flex-col items-center gap-4\" dir=\"rtl\">\n    <Kbd.Group>\n      <Kbd> {\"⌘\"->React.string} </Kbd>\n      <Kbd> {\"⇧\"->React.string} </Kbd>\n      <Kbd> {\"⌥\"->React.string} </Kbd>\n      <Kbd> {\"⌃\"->React.string} </Kbd>\n    </Kbd.Group>\n    <Kbd.Group>\n      <Kbd> {\"Ctrl\"->React.string} </Kbd>\n      <span> {\"+\"->React.string} </span>\n      <Kbd> {\"B\"->React.string} </Kbd>\n    </Kbd.Group>\n  </div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}