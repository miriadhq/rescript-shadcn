{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "InputGroupSpinner",
  "dependencies": [],
  "files": [
    {
      "path": "registry/base/examples/InputGroupSpinner.res",
      "content": "@react.component\nlet make = () =>\n  <div className=\"grid w-full max-w-sm gap-4\">\n    <InputGroup>\n      <InputGroup.Input placeholder=\"Searching...\" />\n      <InputGroup.Addon align=InlineEnd>\n        <Spinner />\n      </InputGroup.Addon>\n    </InputGroup>\n    <InputGroup>\n      <InputGroup.Input placeholder=\"Processing...\" />\n      <InputGroup.Addon>\n        <Spinner />\n      </InputGroup.Addon>\n    </InputGroup>\n    <InputGroup>\n      <InputGroup.Input placeholder=\"Saving changes...\" />\n      <InputGroup.Addon align=InlineEnd>\n        <InputGroup.Text> {\"Saving...\"->React.string} </InputGroup.Text>\n        <Spinner />\n      </InputGroup.Addon>\n    </InputGroup>\n    <InputGroup>\n      <InputGroup.Input placeholder=\"Refreshing data...\" />\n      <InputGroup.Addon>\n        <Icons.Loader2 className=\"animate-spin\" />\n      </InputGroup.Addon>\n      <InputGroup.Addon align=InlineEnd>\n        <InputGroup.Text className=\"text-muted-foreground\">\n          {\"Please wait...\"->React.string}\n        </InputGroup.Text>\n      </InputGroup.Addon>\n    </InputGroup>\n  </div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}