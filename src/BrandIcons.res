let getIconForLanguageExtension = (language: string) => {
  switch language {
  | "json" => <Json />
  | "css" => <Css className="fill-foreground" />
  | "js" | "jsx" | "ts" | "tsx" | "typescript" => <Ts className="fill-foreground" />
  | "res" | "rescript" => <ReScript className="fill-foreground" />
  | _ => <Icons.File />
  }
}
