@react.component
let make = (~name: string) => {
  switch demos->Dict.get(name) {
  | None => React.null
  | Some(module(Comp)) =>
    <React.Suspense fallback={<Skeleton />}>
      <Comp />
    </React.Suspense>
  }
}
