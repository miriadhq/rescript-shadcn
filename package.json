{
  "name": "rescript-shadcn",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "yarn loader:generate && yarn rescript && yarn registry:sync && node scripts/build-with-og.mjs",
    "build:next": "next build",
    "start": "next start",
    "lint": "next lint",
    "registry:sync": "yarn registry:generate && rm -rf public/r && yarn registry:build",
    "registry:build": "shadcn build",
    "registry:generate": "node scripts/generate-registry.mjs",
    "loader:generate": "node scripts/generate-demo-loader.mjs",
    "og:generate": "node scripts/generate-og-images.mjs",
    "test:docs": "vitest run test/mdx-links.test.ts",
    "test:visual": "node test/visual/run-pixel-perfect.mjs",
    "test": "test:docs && test:visual",
    "postInstall": "yarn loader:generate && fumadocs-mdx source.config.mjs .source"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@mdx-js/loader": "^3.1.1",
