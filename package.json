    "fumadocs-mdx": "^14.2.9",
    "fumadocs-ui": "^16.6.14",
    "input-otp": "^1.4.2",
    "lru-cache": "^11.2.6",
    "lucide-react": "^0.487.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
